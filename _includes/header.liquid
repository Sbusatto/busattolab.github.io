<header>
  <!-- Nav Bar -->
  <nav id="navbar" class="navbar navbar-light navbar-expand-sm {% if site.navbar_fixed %}fixed-top{% else %}sticky-top{% endif %}" role="navigation">
    <div class="container">
      
      <!-- LOGO SWAPPER FOR LIGHT/DARK MODE -->
      <style>
        .logo-light { display: inline-block; }
        .logo-dark { display: none; }
        html[data-theme="dark"] .logo-light { display: none; }
        html[data-theme="dark"] .logo-dark { display: inline-block; }
        
        /* Forza il centering e corregge la spaziatura */
        .navbar-nav { width: 100%; justify-content: center; }
        @media (min-width: 576px) {
          .navbar-collapse { justify-content: center !important; }
        }
      </style>

    <!-- Clickable Lab Logo -->
      <a class="navbar-brand" href="{{ site.baseurl }}/" style="display: flex; align-items: center; text-decoration: none;">
        <img src="{{ '/assets/img/logo.png' | relative_url }}" height="70" class="logo-light" alt="Bionano Lab Logo">
        <img src="{{ '/assets/img/logo_dark.png' | relative_url }}" height="70" class="logo-dark" alt="Bionano Lab Logo">
      </a>

      <!-- Navbar Toggle -->
      <button
        class="navbar-toggler collapsed"
        type="button"
        data-toggle="collapse"
        data-target="#navbarNav"
        aria-controls="navbarNav"
        aria-expanded="false"
        aria-label="Toggle navigation"
      >
        <span class="sr-only">Toggle navigation</span>
        <span class="icon-bar top-bar"></span>
        <span class="icon-bar middle-bar"></span>
        <span class="icon-bar bottom-bar"></span>
      </button>

      <!-- Centered Menu -->
      <div class="collapse navbar-collapse text-center" id="navbarNav">
        <ul class="navbar-nav mx-auto flex-nowrap">
          {% for page in site.pages %}
            {% if page.permalink == '/' %} {% assign about_title = page.title %} {% endif %}
          {% endfor %}

          <!-- 1. About (Sempre primo) -->
          <li class="nav-item {% if page.permalink == '/' %}active{% endif %}">
            <a class="nav-link" href="{{ '/' | relative_url }}">
              {{- about_title }}
              {% if page.permalink == '/' %}
                <span class="sr-only">(current)</span>
              {% endif %}
            </a>
          </li>

          <!-- 2. Altre pagine ordinate per nav_order -->
          {% assign sorted_pages = site.pages | sort: 'nav_order' %}
          {% for p in sorted_pages %}
            {% if p.nav and p.autogen == null and p.permalink != '/' %}
              {% if p.dropdown %}
                {% assign has_active_child = false %}
                {% for child in p.children %}
                  {% if page.title == child.title %}
                    {% assign has_active_child = true %}
                  {% endif %}
                {% endfor %}
                <li class="nav-item dropdown {% if page.title == p.title or has_active_child %}active{% endif %}">
                  <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                    {{- p.title }}
                  </a>
                  <div class="dropdown-menu dropdown-menu-right" aria-labelledby="navbarDropdown">
                    {% for child in p.children %}
                      {% if child.title == 'divider' %}
                        <div class="dropdown-divider"></div>
                      {% else %}
                        <a class="dropdown-item {% if page.title == child.title %}active{% endif %}" href="{% if child.permalink contains '://' %}{{ child.permalink }}{% else %}{{ child.permalink | relative_url }}{% endif %}">
                          {{- child.title -}}
                        </a>
                      {% endif %}
                    {% endfor %}
                  </div>
                </li>
              {% else %}
                {% assign parent_link = p.permalink | remove: 'index.html' %}
                <li class="nav-item {% if page.url contains parent_link %}active{% endif %}">
                  {%- if p.permalink contains '://' -%}
                    {%- assign url = p.permalink -%}
                  {%- elsif p.permalink contains '/blog/' -%}
                    {%- assign url = '/blog/' -%}
                  {%- else -%}
                    {%- assign url = p.url -%}
                  {%- endif %}
                  
                  <!-- Special color for "Get in Touch" if title matches -->
                  <a class="nav-link" href="{{ url | relative_url }}" {% if p.title contains 'Touch' %}style="color: #ed1c24 !important; font-weight: bold;"{% endif %}>
                    {{- p.title }}
                  </a>
                </li>
              {% endif %}
            {% endif %}
          {% endfor %}

          <!-- Search & Dark Mode -->
          <div class="d-flex align-items-center justify-content-center ml-lg-3">
            {% if site.search_enabled %}
              <li class="nav-item">
                <button id="search-toggle" title="Search" onclick="openSearchModal()">
                  <span class="nav-link"><i class="fa-solid fa-magnifying-glass"></i></span>
                </button>
              </li>
            {% endif %}
            {% if site.enable_darkmode %}
              <li class="toggle-container">
                <button id="light-toggle" title="Change theme">
                  <i class="fa-half-sun-moon" id="light-toggle-system"></i>
                  <i class="fa-solid fa-moon" id="light-toggle-dark"></i>
                  <i class="fa-solid fa-sun" id="light-toggle-light"></i>
                </button>
              </li>
            {% endif %}
          </div>
        </ul>
      </div>
    </div>
  </nav>
  {% if site.enable_progressbar %}
    <progress id="progress" value="0">
      <div class="progress-container">
        <span class="progress-bar"></span>
      </div>
    </progress>
  {% endif %}
</header>
